# Virtualenvs and Python caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/
.cache/

# Local secrets / env
.env
.env.*

# Ephemeral live-worker state (regenerated at runtime)
state/heartbeat.json
state/position.json
state/reflect_state.json

# Shadow paper lab — per-variant runtime state (Issue #43). Symlinks +
# worker writes; regenerated by `paper_lab.py start`. The lab script
# itself is committed; nothing under state/paper_lab/ should be.
state/paper_lab/

# Large regenerable market data and detailed trade CSVs
state/data/
results/trades_*.csv

# Intermediate machine-readable dumps from research runners
results/.*.json

# Research scratch
research/github_refs/

# OS noise
.DS_Store
Thumbs.db

# Logs
*.log
